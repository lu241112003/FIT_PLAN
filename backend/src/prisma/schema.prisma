generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  ENUMS
// ============================================================

enum Sexo {
  masculino
  feminino
  outro
}

enum Objetivo {
  emagrecimento
  hipertrofia
  condicionamento
  manutencao
  reabilitacao
}

enum Nivel {
  iniciante
  intermediario
  avancado
}

enum DiaSemana {
  segunda
  terca
  quarta
  quinta
  sexta
  sabado
  domingo
}

enum TipoRefeicao {
  cafe_manha
  lanche_manha
  almoco
  lanche_tarde
  jantar
  ceia
}

enum GrupoMuscular {
  peito
  costas
  ombros
  biceps
  triceps
  antebraco
  abdomen
  gluteo
  quadriceps
  posterior_coxa
  panturrilha
  corpo_todo
  cardio
}

enum TipoExercicio {
  forca
  cardio
  flexibilidade
  funcional
  hiit
}

enum StatusPlano {
  ativo
  pausado
  concluido
  arquivado
}

enum StatusGeracao {
  pendente
  processando
  concluido
  erro
}

enum TipoPlano {
  treino
  alimentar
  completo
}

// ============================================================
//  MODEL: User
//  Tabela: users
// ============================================================
model User {
  id              String   @id @default(uuid())
  nome            String   @db.VarChar(120)
  email           String   @unique @db.VarChar(180)
  senhaHash       String   @map("senha_hash")
  fotoUrl         String?  @map("foto_url")
  ativo           Boolean  @default(true)
  emailVerificado Boolean  @default(false) @map("email_verificado")
  refreshToken    String?  @map("refresh_token")
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  profile               UserProfile?
  restricoesAlimentares RestricaoAlimentar[]
  condicoesSaude        CondicaoSaude[]
  aiGeracoes            AiGeracao[]
  planosTreino          PlanoTreino[]
  planosAlimentares     PlanoAlimentar[]
  progressos            ProgressoUsuario[]
  registrosTreino       RegistroTreino[]
  feedbacks             FeedbackPlano[]

  @@map("users")
}

// ============================================================
//  MODEL: UserProfile
//  Tabela: users_profile
// ============================================================
model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  sexo            Sexo
  dataNascimento  DateTime @map("data_nascimento") @db.Date
  pesoKg          Decimal  @map("peso_kg") @db.Decimal(5, 2)
  alturaCm        Int      @map("altura_cm") @db.SmallInt
  gorduraPct      Decimal? @map("gordura_pct") @db.Decimal(4, 1)
  metaPesoKg      Decimal? @map("meta_peso_kg") @db.Decimal(5, 2)
  objetivo        Objetivo
  nivel           Nivel    @default(iniciante)
  diasDisponiveis Int      @default(3) @map("dias_disponiveis") @db.SmallInt
  tempoTreinoMin  Int      @default(60) @map("tempo_treino_min") @db.SmallInt
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("users_profile")
}

// ============================================================
//  MODEL: RestricaoAlimentar
//  Tabela: restricoes_alimentares
// ============================================================
model RestricaoAlimentar {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  restricao String   @db.VarChar(80)
  criadoEm  DateTime @default(now()) @map("criado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("restricoes_alimentares")
}

// ============================================================
//  MODEL: CondicaoSaude
//  Tabela: condicoes_saude
// ============================================================
model CondicaoSaude {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  condicao  String   @db.VarChar(120)
  criadoEm  DateTime @default(now()) @map("criado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("condicoes_saude")
}

// ============================================================
//  MODEL: GrupoMuscularCatalogo
//  Tabela: grupos_musculares
// ============================================================
model GrupoMuscularCatalogo {
  id   Int           @id @default(autoincrement()) @db.SmallInt
  nome String        @unique @db.VarChar(60)
  slug GrupoMuscular @unique

  exerciciosPrimarios   Exercicio[] @relation("GrupoPrimario")
  exerciciosSecundarios Exercicio[] @relation("GrupoSecundario")

  @@map("grupos_musculares")
}

// ============================================================
//  MODEL: Exercicio
//  Tabela: exercicios
// ============================================================
model Exercicio {
  id                String        @id @default(uuid())
  nome              String        @db.VarChar(120)
  descricao         String?
  instrucoes        String?
  tipo              TipoExercicio
  grupoMuscularId   Int?          @map("grupo_muscular_id") @db.SmallInt
  grupoSecundarioId Int?          @map("grupo_secundario_id") @db.SmallInt
  equipamento       String?       @db.VarChar(80)
  nivel             Nivel         @default(iniciante)
  videoUrl          String?       @map("video_url")
  imagemUrl         String?       @map("imagem_url")
  caloriasPorMin    Decimal?      @map("calorias_por_min") @db.Decimal(5, 2)
  ativo             Boolean       @default(true)
  criadoEm          DateTime      @default(now()) @map("criado_em")

  grupoPrimario        GrupoMuscularCatalogo?       @relation("GrupoPrimario", fields: [grupoMuscularId], references: [id])
  grupoSecundario      GrupoMuscularCatalogo?       @relation("GrupoSecundario", fields: [grupoSecundarioId], references: [id])
  sessaoExercicios     SessaoExercicio[]
  registrosRealizados  RegistroExercicioRealizado[]

  @@map("exercicios")
}

// ============================================================
//  MODEL: Alimento
//  Tabela: alimentos
// ============================================================
model Alimento {
  id            String   @id @default(uuid())
  nome          String   @db.VarChar(120)
  porcaoPadraoG Decimal  @default(100) @map("porcao_padrao_g") @db.Decimal(6, 2)
  calorias      Decimal  @db.Decimal(7, 2)
  proteinasG    Decimal  @map("proteinas_g") @db.Decimal(6, 2)
  carboidratosG Decimal  @map("carboidratos_g") @db.Decimal(6, 2)
  gordurasG     Decimal  @map("gorduras_g") @db.Decimal(6, 2)
  fibrasG       Decimal? @map("fibras_g") @db.Decimal(6, 2)
  sodioMg       Decimal? @map("sodio_mg") @db.Decimal(7, 2)
  categoria     String?  @db.VarChar(60)
  vegano        Boolean  @default(false)
  vegetariano   Boolean  @default(false)
  semGluten     Boolean  @default(false) @map("sem_gluten")
  semLactose    Boolean  @default(false) @map("sem_lactose")
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")

  refeicaoAlimentos RefeicaoAlimento[]

  @@map("alimentos")
}

// ============================================================
//  MODEL: TemplateTreino
//  Tabela: templates_treino
// ============================================================
model TemplateTreino {
  id             String   @id @default(uuid())
  codigoPerfil   String   @unique @map("codigo_perfil") @db.VarChar(40)
  nome           String   @db.VarChar(120)
  descricao      String?
  objetivo       Objetivo
  nivel          Nivel
  diasPorSemana  Int      @map("dias_por_semana") @db.SmallInt
  duracaoSemanas Int      @default(12) @map("duracao_semanas") @db.SmallInt
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now()) @map("criado_em")

  planosTreino PlanoTreino[]

  @@map("templates_treino")
}

// ============================================================
//  MODEL: AiGeracao
//  Tabela: ai_geracoes
// ============================================================
model AiGeracao {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  tipo          TipoPlano
  status        StatusGeracao @default(pendente)
  promptEnviado String?       @map("prompt_enviado")
  respostaRaw   String?       @map("resposta_raw")
  tokensUsados  Int?          @map("tokens_usados")
  modeloIa      String?       @map("modelo_ia") @db.VarChar(80)
  tempoMs       Int?          @map("tempo_ms")
  erroMsg       String?       @map("erro_msg")
  criadoEm      DateTime      @default(now()) @map("criado_em")
  concluidoEm   DateTime?     @map("concluido_em")

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planosTreino      PlanoTreino[]
  planosAlimentares PlanoAlimentar[]

  @@map("ai_geracoes")
}

// ============================================================
//  MODEL: PlanoTreino
//  Tabela: planos_treino
// ============================================================
model PlanoTreino {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  aiGeracaoId    String?     @map("ai_geracao_id")
  templateId     String?     @map("template_id")
  nome           String      @db.VarChar(120)
  descricao      String?
  objetivo       Objetivo
  nivel          Nivel
  duracaoSemanas Int         @default(12) @map("duracao_semanas") @db.SmallInt
  status         StatusPlano @default(ativo)
  dataInicio     DateTime?   @map("data_inicio") @db.Date
  dataFim        DateTime?   @map("data_fim") @db.Date
  observacoesIa  String?     @map("observacoes_ia")
  criadoEm       DateTime    @default(now()) @map("criado_em")
  atualizadoEm   DateTime    @updatedAt @map("atualizado_em")

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiGeracao   AiGeracao?      @relation(fields: [aiGeracaoId], references: [id])
  template    TemplateTreino? @relation(fields: [templateId], references: [id])
  sessoes     SessaoTreino[]
  registros   RegistroTreino[]

  @@map("planos_treino")
}

// ============================================================
//  MODEL: SessaoTreino
//  Tabela: sessoes_treino
// ============================================================
model SessaoTreino {
  id            String    @id @default(uuid())
  planoTreinoId String    @map("plano_treino_id")
  diaSemana     DiaSemana @map("dia_semana")
  nomeSessao    String    @map("nome_sessao") @db.VarChar(80)
  ordem         Int       @db.SmallInt
  duracaoMin    Int?      @map("duracao_min") @db.SmallInt
  descricao     String?
  criadoEm      DateTime  @default(now()) @map("criado_em")

  planoTreino PlanoTreino       @relation(fields: [planoTreinoId], references: [id], onDelete: Cascade)
  exercicios  SessaoExercicio[]
  registros   RegistroTreino[]

  @@map("sessoes_treino")
}

// ============================================================
//  MODEL: SessaoExercicio
//  Tabela: sessao_exercicios
// ============================================================
model SessaoExercicio {
  id              String   @id @default(uuid())
  sessaoId        String   @map("sessao_id")
  exercicioId     String   @map("exercicio_id")
  ordem           Int      @db.SmallInt
  series          Int?     @db.SmallInt
  repeticoes      String?  @db.VarChar(20)
  tempoExecucaoS  Int?     @map("tempo_execucao_s") @db.SmallInt
  descansoS       Int?     @default(60) @map("descanso_s") @db.SmallInt
  cargaKg         Decimal? @map("carga_kg") @db.Decimal(5, 2)
  cargaObservacao String?  @map("carga_observacao") @db.VarChar(80)
  observacao      String?
  criadoEm        DateTime @default(now()) @map("criado_em")

  sessao    SessaoTreino @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  exercicio Exercicio    @relation(fields: [exercicioId], references: [id])

  @@map("sessao_exercicios")
}

// ============================================================
//  MODEL: PlanoAlimentar
//  Tabela: planos_alimentares
// ============================================================
model PlanoAlimentar {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  aiGeracaoId       String?     @map("ai_geracao_id")
  nome              String      @db.VarChar(120)
  descricao         String?
  objetivo          Objetivo
  caloriasAlvo      Int?        @map("calorias_alvo")
  proteinasAlvoG    Decimal?    @map("proteinas_alvo_g") @db.Decimal(6, 2)
  carboidratosAlvoG Decimal?    @map("carboidratos_alvo_g") @db.Decimal(6, 2)
  gordurasAlvoG     Decimal?    @map("gorduras_alvo_g") @db.Decimal(6, 2)
  status            StatusPlano @default(ativo)
  dataInicio        DateTime?   @map("data_inicio") @db.Date
  dataFim           DateTime?   @map("data_fim") @db.Date
  observacoesIa     String?     @map("observacoes_ia")
  criadoEm          DateTime    @default(now()) @map("criado_em")
  atualizadoEm      DateTime    @updatedAt @map("atualizado_em")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiGeracao AiGeracao?     @relation(fields: [aiGeracaoId], references: [id])
  dias      DiaAlimentar[]

  @@map("planos_alimentares")
}

// ============================================================
//  MODEL: DiaAlimentar
//  Tabela: dias_alimentares
// ============================================================
model DiaAlimentar {
  id               String     @id @default(uuid())
  planoAlimentarId String     @map("plano_alimentar_id")
  nomeDia          String     @map("nome_dia") @db.VarChar(60)
  ordem            Int        @db.SmallInt
  diaSemana        DiaSemana? @map("dia_semana")
  caloriasTotal    Decimal?   @map("calorias_total") @db.Decimal(7, 2)
  criadoEm         DateTime   @default(now()) @map("criado_em")

  planoAlimentar PlanoAlimentar @relation(fields: [planoAlimentarId], references: [id], onDelete: Cascade)
  refeicoes      Refeicao[]

  @@map("dias_alimentares")
}

// ============================================================
//  MODEL: Refeicao
//  Tabela: refeicoes
// ============================================================
model Refeicao {
  id              String       @id @default(uuid())
  diaAlimentarId  String       @map("dia_alimentar_id")
  tipoRefeicao    TipoRefeicao @map("tipo_refeicao")
  horarioSugerido DateTime?    @map("horario_sugerido") @db.Time()
  nome            String       @db.VarChar(80)
  ordem           Int          @db.SmallInt
  caloriasTotal   Decimal?     @map("calorias_total") @db.Decimal(7, 2)
  observacao      String?
  criadoEm        DateTime     @default(now()) @map("criado_em")

  diaAlimentar DiaAlimentar      @relation(fields: [diaAlimentarId], references: [id], onDelete: Cascade)
  alimentos    RefeicaoAlimento[]

  @@map("refeicoes")
}

// ============================================================
//  MODEL: RefeicaoAlimento
//  Tabela: refeicao_alimentos
// ============================================================
model RefeicaoAlimento {
  id            String   @id @default(uuid())
  refeicaoId    String   @map("refeicao_id")
  alimentoId    String   @map("alimento_id")
  quantidadeG   Decimal  @map("quantidade_g") @db.Decimal(7, 2)
  observacao    String?  @db.VarChar(120)
  calorias      Decimal? @db.Decimal(7, 2)
  proteinasG    Decimal? @map("proteinas_g") @db.Decimal(6, 2)
  carboidratosG Decimal? @map("carboidratos_g") @db.Decimal(6, 2)
  gordurasG     Decimal? @map("gorduras_g") @db.Decimal(6, 2)
  criadoEm      DateTime @default(now()) @map("criado_em")

  refeicao Refeicao  @relation(fields: [refeicaoId], references: [id], onDelete: Cascade)
  alimento Alimento  @relation(fields: [alimentoId], references: [id])

  @@map("refeicao_alimentos")
}

// ============================================================
//  MODEL: ProgressoUsuario
//  Tabela: progresso_usuario
// ============================================================
model ProgressoUsuario {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  dataRegistro DateTime @map("data_registro") @db.Date
  pesoKg       Decimal  @map("peso_kg") @db.Decimal(5, 2)
  gorduraPct   Decimal? @map("gordura_pct") @db.Decimal(4, 1)
  massaMagraKg Decimal? @map("massa_magra_kg") @db.Decimal(5, 2)
  imc          Decimal? @db.Decimal(4, 1)
  fotoUrl      String?  @map("foto_url")
  observacao   String?
  criadoEm     DateTime @default(now()) @map("criado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dataRegistro])
  @@map("progresso_usuario")
}

// ============================================================
//  MODEL: RegistroTreino
//  Tabela: registros_treino
// ============================================================
model RegistroTreino {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  sessaoId      String?  @map("sessao_id")
  planoTreinoId String?  @map("plano_treino_id")
  dataTreino    DateTime @map("data_treino") @db.Date
  duracaoMin    Int?     @map("duracao_min") @db.SmallInt
  concluido     Boolean  @default(false)
  observacao    String?
  criadoEm      DateTime @default(now()) @map("criado_em")

  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessao               SessaoTreino?                @relation(fields: [sessaoId], references: [id])
  planoTreino          PlanoTreino?                 @relation(fields: [planoTreinoId], references: [id])
  exerciciosRealizados RegistroExercicioRealizado[]

  @@map("registros_treino")
}

// ============================================================
//  MODEL: RegistroExercicioRealizado
//  Tabela: registro_exercicio_realizado
// ============================================================
model RegistroExercicioRealizado {
  id               String   @id @default(uuid())
  registroTreinoId String   @map("registro_treino_id")
  exercicioId      String   @map("exercicio_id")
  serie            Int      @db.SmallInt
  repeticoesFeiras Int?     @map("repeticoes_feitas") @db.SmallInt
  cargaKg          Decimal? @map("carga_kg") @db.Decimal(5, 2)
  tempoExecucaoS   Int?     @map("tempo_execucao_s") @db.SmallInt
  observacao       String?  @db.VarChar(200)
  criadoEm         DateTime @default(now()) @map("criado_em")

  registroTreino RegistroTreino @relation(fields: [registroTreinoId], references: [id], onDelete: Cascade)
  exercicio      Exercicio      @relation(fields: [exercicioId], references: [id])

  @@map("registro_exercicio_realizado")
}

// ============================================================
//  MODEL: FeedbackPlano
//  Tabela: feedbacks_plano
// ============================================================
model FeedbackPlano {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tipo       TipoPlano
  planoId    String    @map("plano_id")
  nota       Int?      @db.SmallInt
  comentario String?
  criadoEm   DateTime  @default(now()) @map("criado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedbacks_plano")
}
